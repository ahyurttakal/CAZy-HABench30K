from dataclasses import dataclass
from pathlib import Path
import pandas as pd
import torch
from torch.utils.data import Dataset

@dataclass
class LabelMaps:
    families: list
    classes: list
    family_to_id: dict
    class_to_id: dict
    family_to_class_id: dict

def build_label_maps(df, family_col='family', class_col='class'):
    families = sorted(df[family_col].unique().tolist())
    classes = sorted(df[class_col].unique().tolist())
    family_to_id = {x:i for i,x in enumerate(families)}
    class_to_id = {x:i for i,x in enumerate(classes)}
    family_to_class_id = {}
    for fam, grp in df.groupby(family_col):
        family_to_class_id[family_to_id[fam]] = class_to_id[grp[class_col].mode().iloc[0]]
    return LabelMaps(families, classes, family_to_id, class_to_id, family_to_class_id)

class CAZySequenceDataset(Dataset):
    def __init__(self, frame, tokenizer, label_maps, cfg):
        self.df = frame.reset_index(drop=True)
        self.tokenizer = tokenizer
        self.label_maps = label_maps
        self.cfg = cfg
        self.max_length = cfg['model'].get('max_length', 512)
        self.id_col = cfg['data'].get('protein_id_column','protein_id')
        self.seq_col = cfg['data'].get('sequence_column','sequence')
        self.fam_col = cfg['data'].get('family_column','family')
        self.cls_col = cfg['data'].get('class_column','class')
    def __len__(self): return len(self.df)
    def __getitem__(self, idx):
        row = self.df.iloc[idx]
        enc = self.tokenizer(str(row[self.seq_col]), truncation=True, padding='max_length', max_length=self.max_length, return_tensors='pt')
        item = {k:v.squeeze(0) for k,v in enc.items()}
        item['family_label'] = torch.tensor(self.label_maps.family_to_id[row[self.fam_col]], dtype=torch.long)
        item['class_label'] = torch.tensor(self.label_maps.class_to_id[row[self.cls_col]], dtype=torch.long)
        item['protein_id'] = str(row[self.id_col])
        return item

def load_frames(data_dir, cfg):
    data_dir = Path(data_dir)
    labels = pd.read_csv(data_dir / cfg['data'].get('labels_file','labels.csv'))
    id_col = cfg['data'].get('protein_id_column','protein_id')
    fam_col = cfg['data'].get('family_column','family')
    cls_col = cfg['data'].get('class_column','class')
    maps = build_label_maps(labels, fam_col, cls_col)
    split_dir = data_dir / cfg['data'].get('split_dir','splits')
    def subset(name):
        f = cfg['data'].get(f'{name}_split', f'{name}.csv')
        ids = pd.read_csv(split_dir / f)
        return labels[labels[id_col].isin(ids[id_col])].copy()
    return subset('train'), subset('val'), subset('test'), maps
