data:
  labels_file: labels.csv
  protein_id_column: protein_id
  sequence_column: sequence
  family_column: family
  class_column: class
  split_dir: splits
  train_split: train.csv
  val_split: val.csv
  test_split: test.csv

model:
  backbone: facebook/esm2_t12_35M_UR50D
  max_length: 512
  hidden_dim: 256
  dropout: 0.20
  lora_r: 16
  lora_alpha: 32
  lora_dropout: 0.05
  lora_targets: [query, value]
  use_attention_pooling: true
  use_hch: true
  use_ldam_drw: true

training:
  epochs: 25
  batch_size: 4
  grad_accum: 4
  learning_rate: 0.0001
  weight_decay: 0.01
  max_grad_norm: 1.0
  seed: 1
  num_workers: 0
  drw_start_fraction: 0.50

loss:
  lambda_family: 1.0
  lambda_class: 0.3
  lambda_kl: 0.1
  ldam_max_margin: 0.7
  temperature: 1.0

evaluation:
  ece_bins: 15
