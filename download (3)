import argparse
import pandas as pd
import torch
from torch.utils.data import DataLoader
from transformers import AutoTokenizer
from tqdm import tqdm
from .config import load_yaml
from .data import load_frames, CAZySequenceDataset
from .model import HierESM, simple_loss
from .metrics import summarize
from .utils import ensure_dir, set_seed, get_device, save_json

@torch.no_grad()
def predict(model, loader, device):
    model.eval(); rows=[]
    for batch in tqdm(loader, desc='predict'):
        pids=batch.pop('protein_id'); ft=batch.pop('family_label').cpu().numpy(); ct=batch.pop('class_label').cpu().numpy()
        batch={k:v.to(device) for k,v in batch.items()}
        o=model(**batch); fp=torch.softmax(o['family_logits'],dim=-1).cpu().numpy(); cp=torch.softmax(o['class_logits'],dim=-1).cpu().numpy()
        for i,pid in enumerate(pids): rows.append({'protein_id':pid,'family_true':int(ft[i]),'family_pred':int(fp[i].argmax()),'class_true':int(ct[i]),'class_pred':int(cp[i].argmax()),'family_conf':float(fp[i].max()),'class_conf':float(cp[i].max())})
    return pd.DataFrame(rows)

def main():
    ap=argparse.ArgumentParser(); ap.add_argument('--config',required=True); ap.add_argument('--data_dir',required=True); ap.add_argument('--out_dir',required=True); ap.add_argument('--seed',type=int,default=None); args=ap.parse_args()
    cfg=load_yaml(args.config); seed=args.seed or cfg['training'].get('seed',1); set_seed(seed); device=get_device(); out=ensure_dir(args.out_dir)
    train_df,val_df,test_df,maps=load_frames(args.data_dir,cfg)
    tok=AutoTokenizer.from_pretrained(cfg['model'].get('backbone','facebook/esm2_t12_35M_UR50D'))
    train_ds=CAZySequenceDataset(train_df,tok,maps,cfg); val_ds=CAZySequenceDataset(val_df,tok,maps,cfg); test_ds=CAZySequenceDataset(test_df,tok,maps,cfg)
    bs=cfg['training'].get('batch_size',4)
    train_loader=DataLoader(train_ds,batch_size=bs,shuffle=True,num_workers=cfg['training'].get('num_workers',0)); val_loader=DataLoader(val_ds,batch_size=bs); test_loader=DataLoader(test_ds,batch_size=bs)
    model=HierESM(cfg,maps).to(device); opt=torch.optim.AdamW(model.parameters(), lr=cfg['training'].get('learning_rate',1e-4), weight_decay=cfg['training'].get('weight_decay',1e-2))
    best=-1; accum=cfg['training'].get('grad_accum',4)
    for ep in range(cfg['training'].get('epochs',25)):
        model.train(); opt.zero_grad(set_to_none=True)
        for step,batch in enumerate(tqdm(train_loader, desc=f'epoch {ep+1}')):
            batch.pop('protein_id'); fl=batch.pop('family_label').to(device); cl=batch.pop('class_label').to(device); batch={k:v.to(device) for k,v in batch.items()}
            loss=simple_loss(model(**batch),fl,cl,cfg)/accum; loss.backward()
            if (step+1)%accum==0:
                torch.nn.utils.clip_grad_norm_(model.parameters(), cfg['training'].get('max_grad_norm',1.0)); opt.step(); opt.zero_grad(set_to_none=True)
        val=predict(model,val_loader,device); met=summarize(val.family_true,val.family_pred,val.class_true,val.class_pred); print({'epoch':ep+1,**met})
        if met['family_macro_f1']>best: best=met['family_macro_f1']; torch.save({'model':model.state_dict(),'config':cfg}, out/f'best_seed{seed}.pt')
    pred=predict(model,test_loader,device); pred.to_csv(out/f'predictions_seed{seed}.csv',index=False)
    met=summarize(pred.family_true,pred.family_pred,pred.class_true,pred.class_pred); save_json(met,out/f'metrics_seed{seed}.json'); print(met)
if __name__=='__main__': main()
